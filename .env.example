# ╔══════════════════════════════════════════════════════════════╗
# ║           KelownaFireGuard — Environment Config             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./fireguard.db

# ── NASA FIRMS (REQUIRED) ─────────────────────────────────────
NASA_FIRMS_KEY=DEMO_KEY

# ── OpenWeatherMap (OPTIONAL) ─────────────────────────────────
OPENWEATHER_API_KEY=

# ── Application Settings ──────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO

# ── Monitoring Region ─────────────────────────────────────────
KELOWNA_LAT=49.8880
KELOWNA_LNG=-119.4960
MONITORING_RADIUS_KM=50
BBOX_NORTH=50.15
BBOX_SOUTH=49.60
BBOX_WEST=-119.90
BBOX_EAST=-119.10

# ── AI / NLP Thresholds ──────────────────────────────────────
AI_DETECTION_THRESHOLD=0.75
SOCIAL_SPIKE_THRESHOLD=5
TEMP_ALERT_C=35.0
HUMIDITY_ALERT_PCT=15.0
WIND_ALERT_KMH=40.0

# ── Reddit Poster (OPTIONAL) ──────────────────────────────────
# Create a "script" type app at https://www.reddit.com/prefs/apps
# Use the account that will post (e.g. u/KelownaFireGuard)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_BOT_USER_AGENT=KelownaFireGuard/1.0 by u/YOUR_USERNAME (wildfire monitoring bot)

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws
